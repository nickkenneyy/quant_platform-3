# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://quant:quant_secret@db:5432/quant_db
SYNC_DATABASE_URL=postgresql://quant:quant_secret@db:5432/quant_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Market Data APIs ──────────────────────────────────────────────────────────
POLYGON_API_KEY=your_polygon_key_here
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── News APIs ─────────────────────────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key_here
BENZINGA_API_KEY=your_benzinga_key_here

# ── Fundamentals ──────────────────────────────────────────────────────────────
FMP_API_KEY=your_fmp_key_here

# ── App Config ────────────────────────────────────────────────────────────────
SECRET_KEY=change_me_to_random_string_in_production
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Scan Config ───────────────────────────────────────────────────────────────
SCAN_INTERVAL_SECONDS=300        # Full market scan every 5 min
WATCHLIST_SCAN_SECONDS=60        # Watchlist refresh every 1 min
MIN_MARKET_CAP=500000000         # $500M min market cap
MIN_AVG_VOLUME=1000000           # 1M avg daily volume
MIN_PRICE=5.0                    # No penny stocks
MAX_TICKERS_PER_SCAN=500
